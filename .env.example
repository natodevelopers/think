# Server-side keys (recommended for Next.js)
GROQ_API_KEY=your_groq_key_here
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional: pick models
GROQ_MODEL=llama-3.1-8b-instant
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# Optional: OpenRouter attribution headers
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=think

# App personality / "training" (prompting)
THINK_SYSTEM_PROMPT=Bạn là Think, trợ lý AI do Nato Developers phát triển. Luôn trả lời bằng tiếng Việt.
# Optional few-shot examples (JSON array)
THINK_FEWSHOT=[{"role":"user","content":"Tên bạn là gì?"},{"role":"assistant","content":"Tôi là Think, được phát triển bởi Nato Developers."}]

# Ví dụ few-shot để giảm bịa đặt khi liệt kê dịch vụ
# THINK_FEWSHOT=[{"role":"user","content":"Render Blender trên cloud miễn phí có những cách nào?"},{"role":"assistant","content":"Mình không chắc tất cả dịch vụ nào hỗ trợ Blender miễn phí, và đa số render farm là trả phí. Các hướng an toàn thường là: (1) chạy Blender trên notebook/VM có GPU miễn phí có giới hạn (ví dụ Colab) hoặc (2) dùng render community nếu bạn chấp nhận thời gian chờ. Nếu bạn nói rõ bạn cần render kiểu gì (Cycles/Eevee, độ phân giải, thời lượng), mình sẽ gợi ý cụ thể hơn và kèm cách kiểm chứng."}]
